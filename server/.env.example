# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# PostgreSQL connection string (get from Neon.tech → Project → Connection string)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# JWT signing secret — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-secret

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGIN=http://localhost:5173

# CEO passphrase — used on the hidden "Staff Access" login panel
CEO_SECRET=tablebook-ceo-secret-2024

# ── Twilio SMS (optional — leave blank to use console mock) ───────────────────
# Sign up at https://twilio.com, get a phone number, then fill these in:
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=
